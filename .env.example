# Claves de Supabase (modo nube). Copiá este archivo como ".env.local" y completá los valores.
# Los encontrás en tu proyecto de Supabase → Settings → API.
# Si NO las completás, la app funciona igual usando localStorage (datos solo en cada navegador).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key
